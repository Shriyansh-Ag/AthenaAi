# Document Service Environment Variables

# Server
PORT=4002
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/athena-documents

# JWT (shared secret with auth-service for token verification)
JWT_ACCESS_SECRET=your-access-secret-change-in-production

# CORS
CORS_ORIGIN=http://localhost:3000

# Storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./uploads

# Upload Limits
MAX_FILE_SIZE_MB=50

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
